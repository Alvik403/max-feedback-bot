MAX_BOT_TOKEN=paste_token_here
MONITOR_HOST=0.0.0.0
MONITOR_PORT=15000
# Монитор: хотя бы один из ключей ниже обязателен (иначе вход 503).

# Полный просмотр заявок, в т.ч. ФИО/отдел/модуль у анонимных — задайте одно или оба имени переменной.
MONITOR_SECRET_FULL=your_full_monitor_password
# Либо устаревшее одиночное имя (эквивалент MONITOR_SECRET_FULL):
# MONITOR_SECRET=legacy_single_password

# Режим «без автора» у анонимных в дашборде: в списке и карточке не показываются full_name / department / module.
MONITOR_SECRET_REDACT=your_redacted_monitor_password

DATABASE_PATH=./data/bot.sqlite
LOG_LEVEL=INFO
